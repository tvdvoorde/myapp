# Local Development Environment Variables
# Copy this file to .env.local and fill in the values from Azure Key Vault

# To retrieve these values after infrastructure deployment, run:
# az login
# ENVIRONMENT=dev  # or prd
# KEYVAULT_NAME="kv-linc-${ENVIRONMENT}"
# az keyvault secret show --vault-name $KEYVAULT_NAME --name sql-connection-string --query value -o tsv
# az keyvault secret show --vault-name $KEYVAULT_NAME --name sql-admin-password --query value -o tsv

# SQL Server Configuration
ENVIRONMENT=dev
KEYVAULT_NAME="kv-linc-${ENVIRONMENT}"
export SQL_SERVER=sql-linc-dev.database.windows.net
export SQL_DATABASE=sqldb-linc-dev
export SQL_USER=sqladmin
export SQL_ADMIN_PASSWORD=$(az keyvault secret show --vault-name $KEYVAULT_NAME --name sql-admin-password --query value -o tsv)
export SQL_CONNECTION_STRING=$(az keyvault secret show --vault-name $KEYVAULT_NAME --name sql-connection-string --query value -o tsv)

PORT=8080
